---
- hosts: all
  become: true
  tasks:
    - name: Install apache httpd
      ansible.builtin.apt:
        name: nginx
        state: present
        update_cache: yes
    - name: Copy file with owner and permissions
      ansible.builtin.copy:
        src: /home/ec2-user/index.html
        dest: /usr/share/nginx/html
        owner: root
        group: root
        mode: '0644'
